{
  "expo": {
    "name": "Roadly",
    "slug": "roadly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/roadly-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/brand/roadly-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f1f5f9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "web": {
      "bundler": "metro",
      "lang": "en",
      "description": "Roadly — mechanics, tow, car rental, and roadside help.",
      "themeColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mechnow.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/roadly-adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.mechnow.app"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ]
  }
}
