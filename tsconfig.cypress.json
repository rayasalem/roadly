{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["cypress", "node"],
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["cypress/**/*.ts"]
}
