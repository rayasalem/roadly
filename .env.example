# MechNow Frontend – build-time env (copy to .env)
# Used by Expo; EXPO_PUBLIC_* are baked into the web build.

# Local dev: backend on port 8082 (run backend with PORT=8082)
EXPO_PUBLIC_API_URL=http://localhost:8082
EXPO_PUBLIC_ENVIRONMENT=development

# Optional: force API hostname when auto-detection fails (same Wi‑Fi as the device).
# Run: npm run dev:lan-ip   → copy printed IPv4 here
# EXPO_PUBLIC_DEV_API_HOST=192.168.1.10

# Resolution order (native dev, no manual env):
# 1) EXPO_PUBLIC_DEV_API_HOST
# 2) Metro bundle host (device loading http://YOUR_LAN_IP:8081/...)
# 3) expo-constants hostUri / debuggerHost
# 4) Android emulator → 10.0.2.2 ; iOS Simulator → 127.0.0.1
# If EXPO_PUBLIC_API_URL uses localhost/127.0.0.1 on a phone, env.ts rewrites the host
# to the detected dev machine IP (port/path preserved).

# Debug: log final API_BASE_URL + resolution meta on app load (__DEV__ only)
# EXPO_PUBLIC_DEBUG_HTTP=1

# Explicit LAN API (still valid):
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8082

# Optional: Google Maps / Places (for map search)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here

# Production (Backend on Render): EXPO_PUBLIC_API_URL is optional; defaults to https://roadmapapp.onrender.com
# Override: EXPO_PUBLIC_API_URL=https://roadmapapp.onrender.com
