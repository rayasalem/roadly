# MechNow Frontend – build-time env (copy to .env)
# Used by Expo; EXPO_PUBLIC_* are baked into the web build.

EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_ENVIRONMENT=development

# Optional: Google Maps / Places (for map search)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here

# Staging: set EXPO_PUBLIC_API_URL=https://staging.mechnow.example.com/api
# Production: set EXPO_PUBLIC_API_URL=https://mechnow.example.com/api
