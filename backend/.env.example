NODE_ENV=development
PORT=8082
CLIENT_URL=http://localhost:8081

# Required: PostgreSQL connection string
# Example: postgresql://USER:PASSWORD@localhost:5432/mechnow
DATABASE_URL=

# Required: JWT secrets (min 32 chars each)
JWT_SECRET=
JWT_REFRESH_SECRET=

BCRYPT_ROUNDS=12
# Optional: 32-byte hex key for encryptSensitive/decryptSensitive (e.g. tokens at rest)
# ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
