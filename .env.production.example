# MechNow – Production (Vercel)
# Copy to .env.production or set in Vercel: Project Settings → Environment Variables

# Required: Backend API URL (no trailing slash)
EXPO_PUBLIC_API_URL=https://your-api.example.com

# Optional; defaults to production
EXPO_PUBLIC_ENVIRONMENT=production

# Optional: Google Maps / Places (map search)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here
# EXPO_PUBLIC_GOOGLE_PLACES_KEY=your_key_here
