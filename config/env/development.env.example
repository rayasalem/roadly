# MechNow – Development environment
# Copy to backend/.env and set values. Never commit real secrets.

NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:8082

# Required: generate strong secrets for local dev (min 32 chars)
JWT_SECRET=dev-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=dev-refresh-secret-min-32-chars-long
BCRYPT_ROUNDS=10

# Optional: when using Docker Compose
# DATABASE_URL=postgresql://mechnow:mechnow@db:5432/mechnow
# REDIS_URL=redis://redis:6379
# LOG_LEVEL=debug
