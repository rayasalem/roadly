# MechNow – Production environment
# Set in deployment secrets only. Never commit production secrets.

NODE_ENV=production
PORT=4000
CLIENT_URL=https://mechnow.example.com

JWT_SECRET=<strong-secret-min-32-chars>
JWT_REFRESH_SECRET=<strong-secret-min-32-chars>
BCRYPT_ROUNDS=12

# Production DB (when migrated from in-memory)
# DATABASE_URL=postgresql://user:pass@db:5432/mechnow
# REDIS_URL=redis://redis:6379

LOG_LEVEL=warn
LOG_FORMAT=json

# Rate limiting (optional overrides)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100
