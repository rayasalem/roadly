# MechNow – Staging environment
# Used by CI/CD and staging servers. Set in GitHub Secrets or server env.

NODE_ENV=staging
PORT=4000
CLIENT_URL=https://staging.mechnow.example.com

JWT_SECRET=<from-secrets>
JWT_REFRESH_SECRET=<from-secrets>
BCRYPT_ROUNDS=12

# Staging DB (optional until persistence is added)
# DATABASE_URL=postgresql://user:pass@staging-db:5432/mechnow
# REDIS_URL=redis://staging-redis:6379

# Logging & monitoring
LOG_LEVEL=info
LOG_FORMAT=json

# Feature flags if needed
# FEATURE_X=enabled
